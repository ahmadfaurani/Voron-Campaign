# === Voron-Campaign (HCR-072) — Scoped .gitignore ===
# Purpose: Prevent cross-contamination from other HOI workstreams sharing
# the parent workspace directory. Only Voron-Campaign files should be tracked.

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
*.egg-info/
venv/
env/
.venv

# === Jupyter ===
.ipynb_checkpoints

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === Logs ===
*.log
logs/

# === Temp ===
tmp/
temp/
*.tmp

# === Secrets ===
*.key
*.pem
secrets/
credentials/
.env
.env.local

# === CROSS-CONTAMINATION PREVENTION ===
# These directories belong to OTHER workstreams and must NEVER be tracked
# in the Voron-Campaign repo:
intelligence/
n27-layang-layang/
kempas/
prn-johor-2026/
narrative-tracking/
policing-publications/
sentiment-analysis/
entities/
briefs/
cyber-intel/
gov-intel/
pdrm-io/

# === Nested git repos ===
Voron-Campaign/
vorondrq-prospect-db/
vorondrq-rmit-campaign/

# === Sensitive enrichment data (LinkedIn exports, screenshots) ===
voron-enrichment/
voron-prospects/

# === OpenOSINT ===
openosint-config.env
openosint-env/

# NOTE: CSV and JSON files ARE tracked in this repo.
# The repo's primary purpose is the prospect database CSV.

# === Scratch/working data (not for repo) ===
data/
